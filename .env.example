# Runtime storage
MEMINCEPTION_BASE_DIR=.meminception
MEMINCEPTION_ADMIN_API_PORT=8765
MEMINCEPTION_CORS_ORIGINS=http://localhost:5174

# LLM enrichment
MEMINCEPTION_ENRICHMENT_MODEL=claude-sonnet-4-20250514
MEMINCEPTION_ENRICHMENT_BASE_URL=https://api.anthropic.com
MEMINCEPTION_ENRICHMENT_API_KEY=

# Embeddings
MEMINCEPTION_EMBEDDING_MODEL=text-embedding-3-small
MEMINCEPTION_EMBEDDING_BASE_URL=https://api.openai.com/v1
MEMINCEPTION_EMBEDDING_API_KEY=

# Admin API auth
MEMINCEPTION_JWT_SECRET=change-me-for-any-shared-environment

# Agent adapter overrides
MEMINCEPTION_API_URL=http://127.0.0.1:8765
MEMINCEPTION_API_TOKEN=
MEMINCEPTION_AGENT_QUEUE_DB=
