{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CODEX_PLUGIN_ROOT:-$PLUGIN_ROOT}/scripts/meminception_hook.py\" context --client codex",
            "timeout": 10,
            "statusMessage": "Loading MemInception context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CODEX_PLUGIN_ROOT:-$PLUGIN_ROOT}/scripts/meminception_hook.py\" context --client codex",
            "timeout": 10,
            "statusMessage": "Checking MemInception memory"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CODEX_PLUGIN_ROOT:-$PLUGIN_ROOT}/scripts/meminception_hook.py\" submit-session --client codex",
            "timeout": 15,
            "statusMessage": "Submitting MemInception compaction receipt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CODEX_PLUGIN_ROOT:-$PLUGIN_ROOT}/scripts/meminception_hook.py\" submit-session --client codex",
            "timeout": 15,
            "statusMessage": "Submitting MemInception session receipt"
          }
        ]
      }
    ]
  }
}
